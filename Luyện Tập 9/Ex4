s = input("Nhập chuỗi: ")

upper = lower = digit = special = space = vowel = consonant = 0

nguyen_am = "aeiouAEIOU"

for ch in s:
    if ch.isupper():
        upper += 1
    elif ch.islower():
        lower += 1

    if ch.isdigit():
        digit += 1
    elif not ch.isalnum() and not ch.isspace():
        special += 1

    if ch.isspace():
        space += 1

    if ch.isalpha():
        if ch in nguyen_am:
            vowel += 1
        else:
            consonant += 1

print("In hoa:", upper)
print("In thường:", lower)
print("Chữ số:", digit)
print("Ký tự đặc biệt:", special)
print("Khoảng trắng:", space)
print("Nguyên âm:", vowel)
print("Phụ âm:", consonant)
